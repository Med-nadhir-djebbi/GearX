{% extends 'base.html.twig' %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-light sidebar">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'app_admin_dashboard' ? 'active' }}" href="{{ path('app_admin_dashboard') }}">
                            <i class="bi bi-speedometer2"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'app_admin_product' ? 'active' }}" href="{{ path('app_admin_product_index') }}">
                            <i class="bi bi-box"></i>
                            Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'app_admin_category' ? 'active' }}" href="{{ path('app_admin_category_index') }}">
                            <i class="bi bi-grid"></i>
                            Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'app_admin_order' ? 'active' }}" href="{{ path('app_admin_order_index') }}">
                            <i class="bi bi-cart"></i>
                            Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') starts with 'app_admin_user' ? 'active' }}" href="{{ path('app_admin_user_index') }}">
                            <i class="bi bi-people"></i>
                            Users
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1>{% block admin_title %}{% endblock %}</h1>
                {% block admin_actions %}{% endblock %}
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block admin_content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %} 