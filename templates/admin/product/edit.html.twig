{% extends 'admin/layout.html.twig' %}

{% block title %}Edit Product{% endblock %}

{% block admin_title %}Edit Product{% endblock %}

{% block admin_actions %}
    <div class="btn-group">
        <a href="{{ path('app_admin_product_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <a href="{{ path('app_admin_product_show', {'id': product.id}) }}" class="btn btn-info">
            <i class="bi bi-eye"></i> View
        </a>
    </div>
{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.price) }}
                                {{ form_widget(form.price) }}
                                {{ form_errors(form.price) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.discountPrice) }}
                                {{ form_widget(form.discountPrice) }}
                                {{ form_errors(form.discountPrice) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.stock) }}
                                {{ form_widget(form.stock) }}
                                {{ form_errors(form.stock) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.category) }}
                                {{ form_widget(form.category) }}
                                {{ form_errors(form.category) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    {% if product.image %}
                        <div class="mb-3">
                            <label class="form-label">Current Image</label>
                            <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" class="img-thumbnail">
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        {{ form_label(form.imageFile) }}
                        {{ form_widget(form.imageFile) }}
                        {{ form_errors(form.imageFile) }}
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            {{ form_widget(form.isActive) }}
                            {{ form_label(form.isActive) }}
                        </div>
                        {{ form_errors(form.isActive) }}
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Update Product
                </button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %} 