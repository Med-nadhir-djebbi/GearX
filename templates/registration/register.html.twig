<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - GearX</title>
    
    {# Include Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# Include Font Awesome #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    {# Custom styles #}
    <link rel="stylesheet" href="{{ asset('assets/styles/register.css') }}">
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <h1 class="register-title">Create Account</h1>

            {{ form_start(registrationForm, {'attr': {'class': 'needs-validation'}}) }}
                <div class="mb-4">
                    {{ form_label(registrationForm.email, 'Email address', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Enter your email'
                        }
                    }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="mb-4">
                    {{ form_label(registrationForm.firstName, 'First Name', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.firstName, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Enter your first name'
                        }
                    }) }}
                    {{ form_errors(registrationForm.firstName) }}
                </div>

                <div class="mb-4">
                    {{ form_label(registrationForm.lastName, 'Last Name', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.lastName, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Enter your last name'
                        }
                    }) }}
                    {{ form_errors(registrationForm.lastName) }}
                </div>

                <div class="mb-4">
                    {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Choose a secure password'
                        }
                    }) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        {{ form_widget(registrationForm.agreeTerms, {
                            'attr': {
                                'class': 'form-check-input'
                            }
                        }) }}
                        {{ form_label(registrationForm.agreeTerms, 'I agree to the terms of service', {
                            'label_attr': {
                                'class': 'form-check-label'
                            }
                        }) }}
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                </div>

                <button type="submit" class="register-btn">Create Account</button>
            {{ form_end(registrationForm) }}

            <div class="login-link">
                Already have an account? <a href="{{ path('app_login') }}">Sign in</a>
            </div>

            <div class="back-to-home">
                <a href="{{ path('home') }}">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    </div>

    {# Include Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 